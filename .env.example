# Mock API 风控策略管理系统 - 环境配置

# ==================== 服务基础配置 ====================
# 服务监听端口（默认 8090）
PORT=8090
HOST=0.0.0.0

# 模拟延迟时间（秒），用于测试超时场景
# TIME_TO_SLEEP=2

# 是否记录音频大小信息（默认 false）
# LOG_AUDIO_SIZES=true

# ==================== 数据库配置 ====================
# 数据库类型：mysql 或 sqlite（默认 mysql）
DB_TYPE=mysql
# DB_TYPE=sqlite

# -------------------- MySQL 配置 --------------------
DB_HOST=<Your MySQL Host>
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<Your MySQL PASS>
DB_NAME=<Your MySQL NAME>
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# -------------------- SQLite 配置 --------------------
# SQLite 数据库文件路径（相对于项目根目录，或绝对路径）
# SQLITE_PATH=./data/mock_risk.db

# ==================== 限流与异步配置 ====================
# 全局默认限流 (RPM)
GLOBAL_RPM_LIMIT=1000

# 单 IP 限流 (RPM)
IP_RPM_LIMIT=100

# 单 Key 限流 (RPM)
KEY_RPM_LIMIT=50

# 异步任务并发数
ASYNC_TASK_CONCURRENCY=10

# ==================== 安全配置 ====================
# JWT 密钥（用于管理端认证，可选）
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
